generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum CommitmentStatus {
  COMMITTED
  COMPLETED
  MISSED
  ESCALATED
}

enum CommitmentVisibility {
  PRIVATE
  PAIR
  GROUP
}

enum CheckInMode {
  VIDEO
  AUDIO
  ASYNC_NOTE
}

enum ProofType {
  TEXT
  IMAGE
  LINK
  VIDEO
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AccountTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model User {
  id                   String                      @id @default(cuid())
  name                 String
  email                String                      @unique
  emailVerifiedAt      DateTime?
  passwordHash         String?
  timezone             String                      @default("UTC")
  motivationProfile    String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  tasks                Task[]
  ownedProjects        Project[]
  commitmentsMade      Commitment[]                @relation("CommitmentBy")
  commitmentsReceived  Commitment[]                @relation("CommitmentTo")
  proofsSubmitted      Proof[]                     @relation("ProofBy")
  proofsVerified       Proof[]                     @relation("ProofVerifier")
  reminders            Reminder[]
  calendarConnections  CalendarConnection[]
  activityEvents       ActivityEvent[]
  featureRequests      FeatureRequest[]
  accountTokens        AccountToken[]
  relationshipsAsUser  AccountabilityRelationship[] @relation("RelationshipUser")
  relationshipsAsPeer  AccountabilityRelationship[] @relation("RelationshipPeer")
}

model AccountToken {
  id        String           @id @default(cuid())
  userId    String
  type      AccountTokenType
  tokenHash String           @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model AccountabilityRelationship {
  id            String    @id @default(cuid())
  userId        String
  partnerUserId String
  role          String    @default("peer")
  cadence       String    @default("weekly")
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  user          User      @relation("RelationshipUser", fields: [userId], references: [id])
  partnerUser   User      @relation("RelationshipPeer", fields: [partnerUserId], references: [id])
  checkIns      CheckIn[]

  @@unique([userId, partnerUserId])
}

model Project {
  id          String   @id @default(cuid())
  ownerId     String
  title       String
  description String?
  status      String   @default("active")
  visibility  String   @default("private")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User     @relation(fields: [ownerId], references: [id])
  tasks       Task[]
}

model Task {
  id               String             @id @default(cuid())
  ownerId          String
  projectId        String?
  title            String
  details          String?
  status           TaskStatus         @default(TODO)
  priority         Int                @default(2)
  dueAt            DateTime?
  estimatedMinutes Int?
  riskScore        Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  owner            User               @relation(fields: [ownerId], references: [id])
  project          Project?           @relation(fields: [projectId], references: [id])
  tags             TaskTag[]
  commitments      Commitment[]
  calendarLinks    CalendarEventLink[]
}

model Tag {
  id        String    @id @default(cuid())
  ownerId   String
  name      String
  createdAt DateTime  @default(now())
  tasks     TaskTag[]

  @@unique([ownerId, name])
}

model TaskTag {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model Commitment {
  id              String               @id @default(cuid())
  taskId           String
  committedById    String
  committedToId    String?
  commitAt         DateTime             @default(now())
  dueAt            DateTime?
  visibilityScope  CommitmentVisibility @default(PAIR)
  status           CommitmentStatus     @default(COMMITTED)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  task             Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  committedBy      User                 @relation("CommitmentBy", fields: [committedById], references: [id])
  committedTo      User?                @relation("CommitmentTo", fields: [committedToId], references: [id])
  proofs           Proof[]
}

model CheckIn {
  id               String      @id @default(cuid())
  relationshipId   String
  scheduledAt      DateTime
  mode             CheckInMode @default(VIDEO)
  agenda           String?
  outcome          String?
  nextCommitments  String?
  createdAt        DateTime    @default(now())
  relationship     AccountabilityRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
}

model Proof {
  id                 String             @id @default(cuid())
  commitmentId       String
  submittedById      String
  type               ProofType          @default(TEXT)
  content            String
  submittedAt        DateTime           @default(now())
  verifiedById       String?
  verificationStatus VerificationStatus @default(PENDING)
  commitment         Commitment         @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  submittedBy        User               @relation("ProofBy", fields: [submittedById], references: [id])
  verifiedBy         User?              @relation("ProofVerifier", fields: [verifiedById], references: [id])
}

model CalendarConnection {
  id            String   @id @default(cuid())
  userId        String
  provider      String
  tokensRef     String?
  syncState     String?  @default("idle")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model CalendarEventLink {
  id              String   @id @default(cuid())
  taskId           String
  externalEventId  String
  startAt          DateTime
  endAt            DateTime
  writeSource      String   @default("dueforge")
  task             Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String   @id @default(cuid())
  userId      String
  entityType  String
  entityId    String
  channel     String
  sendAt      DateTime
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityEvent {
  id          String   @id @default(cuid())
  actorId     String
  entityType  String
  entityId    String
  eventType   String
  payloadJson Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
}

model FeatureRequest {
  id         String   @id @default(cuid())
  requestId  String   @unique
  actorId    String?
  source     String
  title      String
  problem    String
  impact     String
  name       String?
  email      String?
  metadataJson Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([source])
}
